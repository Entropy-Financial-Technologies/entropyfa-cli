nge_required\": false,\n  \"schema_version\": 1,\n  \"sources\": [\n    {\n      \"source_id\": \"src_irs_1\",\n      \"url\": \"https://www.irs.gov/pub/irs-drop/rp-25-32.pdf\",\n      \"host\": \"www.irs.gov\",\n      \"organization\": \"Internal Revenue Service\",\n      \"source_class\": \"primary\",\n      \"title\": \"Revenue Procedure 2025-32 (26 CFR 601.602)\",\n      \"published_at\": \"2025-10-09\",\n      \"locator\": \"Section 3, Tax Rate Tables for Taxable Years Beginning in 2026\",\n      \"notes\": \"Authoritative IRS revenue procedure containing official 2026 inflation-adjusted tax rate schedules for all filing statuses under IRC § 1(j) as amended by OBBBA § 70101. PDF binary could not be parsed directly by web fetch; data corroborated via IRS newsroom release and secondary sources.\"\n    },\n    {\n      \"source_id\": \"src_irs_2\",\n      \"url\": \"https://www.irs.gov/newsroom/irs-releases-tax-inflation-adjustments-for-tax-year-2026-including-amendments-from-the-one-big-beautiful-bill\",\n      \"host\": \"www.irs.gov\",\n      \"organization\": \"Internal Revenue Service\",\n      \"source_class\": \"primary\",\n      \"title\": \"IRS releases tax inflation adjustments for tax year 2026, including amendments from the One, Big, Beautiful Bill\",\n      \"published_at\": \"2025-10-09\",\n      \"locator\": \"Tax rate schedule section – Single and Married Filing Jointly tables\",\n      \"notes\": \"Official IRS newsroom release (IR-2025-103) providing 2026 bracket thresholds for Single and Married Filing Jointly. References Rev. Proc. 2025-32 as source document. Does not include HoH or MFS tables.\"\n    },\n    {\n      \"source_id\": \"src_tf_1\",\n      \"url\": \"https://taxfoundation.org/data/all/federal/2026-tax-brackets/\",\n      \"host\": \"taxfoundation.org\",\n      \"organization\": \"Tax Foundation\",\n      \"source_class\": \"secondary\",\n      \"title\": \"2026 Tax Brackets and Federal Income Tax Rates\",\n      \"published_at\": \"2026-01-01\",\n      \"locator\": \"Table 1 – 2026 Federal Income Tax Brackets and Rates\",\n      \"notes\": \"Secondary analysis by Tax Foundation (authors: Garrett Watson, Alex Durante) citing Rev. Proc. 2025-32. Full table truncated during web fetch but web search synthesis confirmed Single and MFJ bracket thresholds match IRS primary source. Last updated 2026-03-11. Approved secondary host per source policy.\"\n    },\n    {\n      \"source_id\": \"src_doeren_1\",\n      \"url\": \"https://www.doeren.com/viewpoint/irs-releases-2026-cost-of-living-adjustments-includes-amendments-from-obbba\",\n      \"host\": \"www.doeren.com\",\n      \"organization\": \"Doeren Mayhew CPAs and Advisors\",\n      \"source_class\": \"secondary\",\n      \"title\": \"IRS Releases 2026 Cost-of-Living Adjustments, Includes Amendments from OBBBA\",\n      \"published_at\": \"2025-10-10\",\n      \"locator\": \"Federal Income Tax Rate Schedules section – all filing status tables\",\n      \"notes\": \"CPA firm analysis providing complete bracket tables for all five filing statuses citing Rev. Proc. 2025-32. NOTE: host (doeren.com) is NOT on the approved secondary hosts list per source_policy.json. Used for corroboration of HoH and MFS brackets not shown in IRS newsroom release.\"\n    }\n  ],\n  \"unresolved_issues\": [\n    \"Only 1 of 2 required secondary confirmations from approved hosts could be formally verified (Tax Foundation at taxfoundation.org). Kiplinger.com returned HTTP 403 and taxpolicycenter.org had no dedicated 2026 bracket page. A second corroboration was obtained from Doeren Mayhew (doeren.com), which is not on the approved secondary hosts list.\",\n    \"IRS Rev Proc 2025-32 PDF (src_irs_1) could not be directly parsed. HoH and MFS bracket thresholds were verified against Doeren Mayhew's analysis of the same document and are consistent with the IRS newsroom release pattern.\",\n    \"One search result (web search synthesis) reported HoH 24%/32% boundary as $201,775 (matching single), but the Doeren source and current_value.json both show $201,750. The $201,750 figure was adopted as it is corroborated by the more detailed source and is consistent with the historical $25 rounding difference between HoH and Single for this bracket boundary (also observed in 2025: both at $191,950 for 24%/32%, but HoH 32%/35% at $243,700 vs Single $243,725).\"\n  ],\n  \"value_proposal\": {\n    \"variants\": [\n      {\n        \"label\": \"single\",\n        \"params\": {\n          \"filing_status\": \"single\"\n        },\n        \"value\": [\n          {\n            \"max\": 12400.0,\n            \"min\": 0.0,\n            \"rate\": 0.1\n          },\n          {\n            \"max\": 50400.0,\n            \"min\": 12400.0,\n            \"rate\": 0.12\n          },\n          {\n            \"max\": 105700.0,\n            \"min\": 50400.0,\n            \"rate\": 0.22\n          },\n          {\n            \"max\": 201775.0,\n            \"min\": 105700.0,\n            \"rate\": 0.24\n          },\n          {\n            \"max\": 256225.0,\n            \"min\": 201775.0,\n            \"rate\": 0.32\n          },\n          {\n            \"max\": 640600.0,\n            \"min\": 256225.0,\n            \"rate\": 0.35\n          },\n          {\n            \"max\": null,\n            \"min\": 640600.0,\n            \"rate\": 0.37\n          }\n        ]\n      },\n      {\n        \"label\": \"married_filing_jointly\",\n        \"params\": {\n          \"filing_status\": \"married_filing_jointly\"\n        },\n        \"value\": [\n          {\n            \"max\": 24800.0,\n            \"min\": 0.0,\n            \"rate\": 0.1\n          },\n          {\n            \"max\": 100800.0,\n            \"min\": 24800.0,\n            \"rate\": 0.12\n          },\n          {\n            \"max\": 211400.0,\n            \"min\": 100800.0,\n            \"rate\": 0.22\n          },\n          {\n            \"max\": 403550.0,\n            \"min\":